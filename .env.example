# LLM (Required)
PLANNER_MODEL=llama-3.1-8b-instant
EXECUTOR_MODEL=llama-3.1-8b-instant
EVALUATOR_MODEL=llama-3.1-8b-instant

# Groq
GROQ_API_KEY=gsk_your-key-here

# Code Execution
USE_LOCAL_SANDBOX=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=''
REDIS_TTL=3600

# Memory
CHROMA_PERSIST_DIR=./data/memory

# Agent Behavior
MAX_ITERATIONS=15
MAX_RETRIES_PER_STEP=3
CONFIDENCE_THRESHOLD=0.7
ENABLE_SELF_CORRECTION=true

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
